# BookSearch Configuration
# ========================

# Admin credentials (used on first run only)
DEFAULT_USER=admin
DEFAULT_PASS=admin

# Flask session secret — CHANGE THIS to a random string!
SECRET_KEY=change-me-to-random-string

# Timezone
TZ=Etc/UTC

# File permissions (match your host user)
PUID=1000
PGID=1000

# Port configuration (change if you have conflicts)
BOOKSEARCH_PORT=5000
STACKS_PORT=8585
CALIBRE_PORT=8182
CALIBRE_WEB_PORT=8084
CALIBRE_CONTENT_PORT=8181

# Kindle settings are configured in BookSearch UI (Settings page)
# No environment variables needed for Kindle
